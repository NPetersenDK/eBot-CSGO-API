# Copy to .env and adjust. All values are read from the environment.

# Required: shared secret clients send as the X-API-Key header.
API_KEY=change-me

# HTTP listen address.
HTTP_ADDR=:8080

# Database — either set a full DSN...
# DB_DSN=root:@tcp(127.0.0.1:3306)/ebotv3?parseTime=true&charset=utf8mb4&loc=Local

# ...or the discrete parts (defaults mirror eBot-CSGO-Web/config/databases.yml).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ebotv3
DB_USER=root
DB_PASS=
