# Copy to .env and adjust. All values are read from the environment.
# The MYSQL_* names match the existing eBot docker-compose stack (eBot-docker/.env).

# Required: shared secret clients send as the X-API-Key header.
API_KEY=change-me

# HTTP listen address.
HTTP_ADDR=:8080

# Database — shared with the eBot stack.
MYSQL_HOST=mysqldb
MYSQL_PORT=3306
MYSQL_DATABASE=ebotv3
MYSQL_USER=ebotv3
MYSQL_PASSWORD=change-me

# Optional: a full Go MySQL DSN. When set, it overrides all MYSQL_* values above.
# DB_DSN=ebotv3:secret@tcp(mysqldb:3306)/ebotv3?parseTime=true&charset=utf8mb4&loc=Local
